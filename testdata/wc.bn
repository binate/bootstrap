package "main"

import "pkg/bootstrap"

func main() {
	a := bootstrap.Args()
	if len(a) == 0 {
		println("usage: wc <file>")
		bootstrap.Exit(1)
	}
	fd := bootstrap.Open(a[0], 0)
	if fd < 0 {
		println("error: could not open file")
		bootstrap.Exit(1)
	}

	lines := 0
	words := 0
	chars := 0
	inWord := false
	buf := make([]byte, 4096)

	for {
		n := bootstrap.Read(fd, buf, 4096)
		if n <= 0 {
			break
		}
		for i := 0; i < n; i++ {
			c := buf[i]
			chars++
			if c == 10 {
				lines++
			}
			if c == 32 || c == 9 || c == 10 || c == 13 {
				inWord = false
			} else if !inWord {
				inWord = true
				words++
			}
		}
	}
	bootstrap.Close(fd)

	println(lines, words, chars)
}
