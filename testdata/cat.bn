package "main"

import "pkg/bootstrap"

func main() {
	a := bootstrap.Args()
	if len(a) == 0 {
		println("usage: cat <file>")
		bootstrap.Exit(1)
	}
	fd := bootstrap.Open(a[0], bootstrap.O_RDONLY)
	if fd < 0 {
		println("error: could not open file")
		bootstrap.Exit(1)
	}
	buf := make([]byte, 4096)
	for {
		n := bootstrap.Read(fd, buf, 4096)
		if n <= 0 {
			break
		}
		bootstrap.Write(bootstrap.STDOUT, buf, n)
	}
	bootstrap.Close(fd)
}
